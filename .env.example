# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fitfamily

# Clerk Auth — all read at RUNTIME, nothing baked into the image.
# Keys: https://dashboard.clerk.com -> API Keys
# Note: no NEXT_PUBLIC_ prefix. The publishable key is passed to ClerkProvider
# at runtime so the published image stays generic — operators supply their own.
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Webhook signing secret. Create endpoint at <public-url>/api/webhooks/clerk
# subscribed to user.created, then copy its signing secret here.
# Local dev: expose port 3000 with `ngrok http 3000` and use the ngrok URL.
CLERK_WEBHOOK_SECRET=whsec_...
